# Copy this file to notion.env and fill in your values.
# Never commit notion.env — it is in .gitignore.

# Notion Integration token (starts with secret_...)
NOTION_TOKEN=

# Your Leads database ID from Notion
NOTION_LEADS_DB_ID=

# Telegram bot token (from @BotFather) — optional, needed for telegram_bot.py
TELEGRAM_TOKEN=

# Your Telegram user/chat ID — optional
TELEGRAM_CHAT_ID=

# Google Places API key (New Places API, not legacy)
GOOGLE_PLACES_API_KEY=
